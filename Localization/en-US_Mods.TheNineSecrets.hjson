Mods.TheNineSecrets.DisplayName: The Nine Secrets

Items: {
	// Tier 1 Base Secrets
	DouSecret: {
		Name: Dou Seal
		Tooltip:
			'''
			Increases melee damage by 8%
			3% chance for an extra strike on melee hits
			'The power of battle'
			'''
		DisplayName: Dou Seal
	}

	ZheSecret: {
		Name: Zhe Seal
		Tooltip:
			'''
			Increases life regeneration by 1 HP/s
			An additional 3 HP/s when taking damage
			'The power of healing'
			'''
		DisplayName: Zhe Seal
	}

	LinSecret: {
		Name: Lin Seal
		Tooltip:
			'''
			Increases defense by 10%
			Survive fatal damage once (60 second cooldown)
			'The power of protection'
			'''
		DisplayName: Lin Seal
	}

	BingSecret: {
		Name: Bing Seal
		Tooltip:
			'''
			Increases all damage by 5%
			Increases knockback by 25%
			'The power of the warrior'
			'''
		DisplayName: Bing Seal
	}

	JieSecret: {
		Name: Jie Seal
		Tooltip:
			'''
			Increases critical strike chance by 5%
			Increases item drop rates by 8%
			'The power of fortune'
			'''
		DisplayName: Jie Seal
	}

	ZhenSecret: {
		Name: Zhen Seal
		Tooltip:
			'''
			Summons 2 orbiting runes dealing 25 DPS
			'The power of arrays'
			'''
		DisplayName: Zhen Seal
	}

	LieSecret: {
		Name: Lie Seal
		Tooltip:
			'''
			Increases movement speed by 13%
			Increases flight time by 100%
			'The power of swiftness'
			'''
		DisplayName: Lie Seal
	}

	XingSecret: {
		Name: Xing Seal
		Tooltip:
			'''
			10% chance to dodge attacks
			Dodging grants 50% movement speed for 3 seconds
			'The power of evasion'
			'''
		DisplayName: Xing Seal
	}

	QianSecret: {
		Name: Qian Seal
		Tooltip:
			'''
			Double tap DOWN to activate bullet time for 2.5s (120s cooldown)
			Increases critical damage by 5%
			'The power of time'
			'''
		DisplayName: Qian Seal
	}

	// Tier 2 Combined Secrets
	DouBingSecret: {
		Name: Dou-Bing Seal
