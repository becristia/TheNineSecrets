			'The way of fortune arrays'
			'''
		DisplayName: Zhen-Jie Seal
	}

	// Tier 3 Triple Secrets
	ZhanShengSecret: {
		Name: War Saint Seal
		Tooltip:
			'''
			18% all damage, 15% melee damage
			8% extra strike chance
			38% knockback
