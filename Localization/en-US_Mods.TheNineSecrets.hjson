		DisplayName: Dou-Bing Seal
	}

	ZheLinSecret: {
		Name: Zhe-Lin Seal
		Tooltip:
			'''
			Increases life regeneration by 3 HP/s
			Increases defense by 8%
			Death save ability (45s cooldown)
			'The way of eternal life'
			'''
		DisplayName: Zhe-Lin Seal
	}

	JieQianSecret: {
		Name: Jie-Qian Seal
		Tooltip:
			'''
			Increases critical chance by 10%
			Increases critical damage by 10%
			Bullet time duration: 3.5s (90s cooldown)
			'The way of perfect strikes'
			'''
		DisplayName: Jie-Qian Seal
	}

	XingLieSecret: {
		Name: Xing-Lie Seal
		Tooltip:
			'''
			13% dodge chance
			25% movement speed
			100% flight time
			Speed boost after dodging
			'The way of the phantom'
			'''
		DisplayName: Xing-Lie Seal
	}

	ZhenJieSecret: {
		Name: Zhen-Jie Seal
		Tooltip:
			'''
			4 orbiting runes (40 damage each)
